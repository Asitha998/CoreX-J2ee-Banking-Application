<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CoreX Banking</title> <%-- This title will be overridden by individual JSP titles --%>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts - Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Custom CoreX Theme Stylesheet -->
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body class="flex flex-col min-h-screen">

<!-- Reusable Header -->
<header class="bg-gray-900 text-light-gray shadow-lg py-4">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gold flex items-center">
            <i class="fas fa-university mr-3 text-3xl"></i> CoreX Banking
        </h1>
        <nav class="space-x-6">
            <a href="${pageContext.request.contextPath}/user/dashboard.jsp" class="text-medium-gray hover:text-gold hover:underline transition duration-200 font-medium">Dashboard</a>
            <a href="${pageContext.request.contextPath}/logout" class="btn-primary px-4 py-2 rounded-lg font-semibold shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gold transition duration-300 flex items-center inline-flex">
                <i class="fas fa-sign-out-alt mr-2"></i> Logout
            </a>
        </nav>
    </div>
</header>

<%-- Main content will be inserted here by individual JSPs --%>
<div class="flex-grow">
    <%-- This div is a placeholder for the main content of each JSP --%>
</div>

<!-- Reusable Footer -->
<footer class="bg-gray-900 text-center py-6 text-sm text-medium-gray shadow-inner mt-auto">
    <p>&copy; 2025 CoreX Banking. All rights reserved.</p>
    <p class="mt-1 text-xs text-dark-gray">Designed with security and elegance in mind.</p>
</footer>

</body>
</html>
